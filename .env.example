# Required for authenticated tools (5-10). Public tools (1-4) work without it.
PEAR_API_KEY=

# Required when using PEAR_API_KEY — the wallet address bound to your API key.
PEAR_ADDRESS=

# Optional. Defaults shown.
PEAR_API_BASE_URL=https://hl-v2.pearprotocol.io
PEAR_API_TIMEOUT_MS=10000
PEAR_CLIENT_ID=APITRADER
